# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme
POSTGRES_URL=postgresql+asyncpg://colossus:changeme@colossus-db:5432/colossus

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://colossus-redis:6379/0

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_USER=colossus
MINIO_PASSWORD=changeme
MINIO_ENDPOINT=colossus-minio:9000
MINIO_BUCKET=colossus

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=changeme_replace_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Google OAuth (used for Calendar integration in Phase 6) ──────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
